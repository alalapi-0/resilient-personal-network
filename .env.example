PROJECT_NAME=resilient-personal-network
DEFAULT_REGION=jp-tokyo
DEFAULT_PROTOCOL=vless-reality
DEFAULT_CLIENT=sing-box

# 以下内容只是占位符，不要填写真实密钥后提交到 GitHub
SERVER_HOST=example.com
SERVER_PORT=443
NODE_NAME=jp-tokyo-01

# Round 1：VPS 初始化占位符
# 真实 IP、SSH 用户和端口建议通过运行命令时传入，不要提交真实值。
VPS_HOST=<your_vps_ip_or_domain>
SSH_USER=root
SSH_PORT=22
REMOTE_PROJECT_DIR=/opt/resilient-personal-network

# Round 2：Xray / VLESS + REALITY 服务端占位符
# 以下值只作为模板说明，真实值不要提交到 Git。
XRAY_VERSION=latest
XRAY_PORT=443
XRAY_UUID=<generated_by_xray_uuid>
XRAY_FLOW=xtls-rprx-vision
XRAY_CLIENT_NAME=<client_name>
XRAY_REALITY_PRIVATE_KEY=<generated_by_xray_x25519_private_key>
XRAY_REALITY_PUBLIC_KEY=<generated_by_xray_x25519_public_key>
XRAY_REALITY_SHORT_ID=<generated_by_openssl_rand_hex_8>
XRAY_REALITY_DEST=www.microsoft.com:443
XRAY_SERVER_NAME=www.microsoft.com
XRAY_LOG_LEVEL=warning

# Round 3：客户端配置占位符
# 真实客户端配置与真实导入链接不要提交到 Git。
NODE_HOST=<your_vps_ip_or_domain>
NODE_PORT=443
SINGBOX_LOG_LEVEL=info
SINGBOX_MIXED_PORT=2080
CLIENT_FINGERPRINT=chrome
