{
  "log": {
    "level": "${SINGBOX_LOG_LEVEL}",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "cloudflare",
        "address": "https://1.1.1.1/dns-query",
        "detour": "proxy"
      },
      {
        "tag": "local",
        "address": "local"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "local"
      }
    ],
    "final": "cloudflare"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.18.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "strict_route": true
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "node-primary",
        "direct"
      ],
      "default": "node-primary"
    },
    {
      "type": "vless",
      "tag": "node-primary",
      "server": "${NODE_HOST}",
      "server_port": ${NODE_PORT},
      "uuid": "${XRAY_UUID}",
      "flow": "${XRAY_FLOW}",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "${XRAY_SERVER_NAME}",
        "utls": {
          "enabled": true,
          "fingerprint": "${CLIENT_FINGERPRINT}"
        },
        "reality": {
          "enabled": true,
          "public_key": "${XRAY_REALITY_PUBLIC_KEY}",
          "short_id": "${XRAY_REALITY_SHORT_ID}"
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "inbound": "tun-in",
        "action": "sniff",
        "timeout": "1s"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      }
    ],
    "final": "proxy",
    "auto_detect_interface": true
  }
}
